###################################################
# Batch running of events  
###################################################

# verbosity
/tracking/verbose 0
/control/verbose 0
/run/verbose 0
# can be csv, root or hdf5
/RunAction/output/file PerformanceTest.root

# PrimaryGenerationAction
/PrimaryGenerationAction/input/type Performance # GPS, Performance, or use ROOT
/run/beamOn 11